{
  "name": "etsymargin",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=22"
  },
  "browserslist": [
    "chrome >= 100",
    "firefox >= 100",
    "edge >= 100",
    "safari >= 16",
    "not dead",
    "not op_mini all"
  ],
  "scripts": {
    "dev": "next dev",
    "prebuild": "node scripts/build-changelog.mjs && tsx scripts/generate-favicon.ts",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "lhci": "lhci autorun --config=./lighthouserc.json",
    "changelog": "node scripts/build-changelog.mjs",
    "indexnow": "node scripts/indexnow-ping.mjs",
    "build:product": "tsx scripts/build-product.ts",
    "build:images": "tsx scripts/build-images.ts",
    "build:icons": "tsx scripts/generate-favicon.ts"
  },
  "dependencies": {
    "@next/third-parties": "^16.2.7",
    "@vercel/analytics": "^1.6.1",
    "@vercel/speed-insights": "^1.2.0",
    "next": "^15.1.0",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-slug": "^6.0.0",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@eslint/eslintrc": "^3.2.0",
    "@lhci/cli": "^0.15.0",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.19.19",
    "@types/pdfkit": "^0.13.0",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.0.0",
    "eslint": "^9.16.0",
    "eslint-config-next": "^15.1.0",
    "eslint-config-prettier": "^10.1.8",
    "pdfkit": "^0.18.0",
    "prettier": "^3.4.0",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
