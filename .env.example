# Vertex Network env contract — see vertex-hub/config/env.template.json.
# Identity (required) -------------------------------------------------------
NEXT_PUBLIC_SITE_NAME=Etsy Margin
NEXT_PUBLIC_SITE_SHORT_NAME=EtsyMargin
NEXT_PUBLIC_SITE_DOMAIN=etsymargin.tools
NEXT_PUBLIC_SITE_URL=https://etsymargin.tools
NEXT_PUBLIC_SITE_DESCRIPTION=Free Etsy profit calculator. See your true net profit and margin after every layered platform fee, including the 12–15% Off-Site Ads cut.
NEXT_PUBLIC_SITE_CONTACT_EMAIL=hello@etsymargin.tools
NEXT_PUBLIC_SECURITY_CONTACT=mailto:security@etsymargin.tools

# SEO verification ----------------------------------------------------------
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
NEXT_PUBLIC_BING_SITE_VERIFICATION=

# Analytics -----------------------------------------------------------------
NEXT_PUBLIC_VERCEL_ANALYTICS=1
NEXT_PUBLIC_CLARITY_PROJECT_ID=
# NEXT_PUBLIC_PLAUSIBLE_DOMAIN=
# NEXT_PUBLIC_GA_ID=

# Ad provider switch --------------------------------------------------------
# Etsy Margin ships ads OFF — the Pricing Bible PDF is the revenue lever
# and display ads on a fee-transparency tool undercut the trust funnel.
NEXT_PUBLIC_AD_PROVIDER=none
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
# NEXT_PUBLIC_MEDIAVINE_SITE_ID=
# NEXT_PUBLIC_CARBONADS_SERVE_ID=
# NEXT_PUBLIC_CARBONADS_PLACEMENT=

# Affiliate (single generic slot) -------------------------------------------
NEXT_PUBLIC_AFFILIATE_ENABLED=1
NEXT_PUBLIC_AFFILIATE_URL=https://try.printify.com/j8xm11chwojf
NEXT_PUBLIC_AFFILIATE_LABEL=Lower your fees
NEXT_PUBLIC_AFFILIATE_PROVIDER=printify

# Email capture (Resend, opt-in) -------------------------------------------
# RESEND_API_KEY=
# RESEND_AUDIENCE_ID=

# Stripe Pro tier (opt-in, off here) ----------------------------------------
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# NEXT_PUBLIC_PRO_ENABLED=0
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# NEXT_PUBLIC_STRIPE_PRICE_MONTHLY=
# NEXT_PUBLIC_STRIPE_PRICE_YEARLY=

# Lemon Squeezy / Gumroad (Gumroad is the revenue lever for this site) ------
# NEXT_PUBLIC_LEMON_SQUEEZY_STORE_ID=
NEXT_PUBLIC_GUMROAD_ENABLED=1
NEXT_PUBLIC_GUMROAD_PRODUCT_URL=
NEXT_PUBLIC_GUMROAD_PRICE=19

# Embed widget (on by default for Etsy Margin) ------------------------------
NEXT_PUBLIC_EMBED_ENABLED=1

# Bulk Shop Audit (gated tool, opt-in) --------------------------------------
# The painkiller: buyers upload their Etsy export and audit every listing.
# Public flag toggles the route + homepage teaser.
NEXT_PUBLIC_AUDIT_ENABLED=0
# Server-only (set in Vercel project env — NEVER prefix with NEXT_PUBLIC_):
# GUMROAD_PRODUCT_ID=          # product id (post-2023 products need id, not permalink)
# AUDIT_TOKEN_SECRET=          # long random string; signs the unlock cookie
# AUDIT_USES_CAP=5             # max license activations before sharing is blocked
