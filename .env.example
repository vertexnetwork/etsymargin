# Analytics
NEXT_PUBLIC_GA_ID=
NEXT_PUBLIC_CLARITY_PROJECT_ID=

# Mediavine — master ad network. When enabled, takes precedence over AdSense.
NEXT_PUBLIC_GROW_ME_SITE_ID=
NEXT_PUBLIC_MEDIAVINE_ENABLED=0

# Google AdSense — bridge ad network until Mediavine activates. Suppressed
# automatically when NEXT_PUBLIC_MEDIAVINE_ENABLED=1.
NEXT_PUBLIC_ADSENSE_ENABLED=0
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-6985819972152617

# Gumroad PDF storefront — flip ENABLED=1 once the product URL is set.
NEXT_PUBLIC_GUMROAD_ENABLED=0
NEXT_PUBLIC_GUMROAD_PRODUCT_URL=
NEXT_PUBLIC_GUMROAD_PRICE=9
